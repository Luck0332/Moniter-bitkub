{
  "name": "liberix-monitor",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create liberix-loans",
    "db:migrate": "wrangler d1 execute liberix-loans --file=migrations/0001_create_loans.sql",
    "db:migrate:remote": "wrangler d1 execute liberix-loans --file=migrations/0001_create_loans.sql --remote",
    "pages:deploy": "wrangler pages deploy frontend/ --project-name=liberix-monitor"
  },
  "dependencies": {
    "hono": "^4.0.0"
  },
  "devDependencies": {
    "wrangler": "^3.0.0"
  }
}
